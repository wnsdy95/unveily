{
  "name": "unveily",
  "description": "Local-first Chrome extension for terms, privacy, consent, and behavior-policy analysis.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "test:e2e:chrome": "node scripts/e2e-companion.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-coverage-exclude='src/background.js' --test-coverage-lines=80 --test-coverage-branches=70 --test-coverage-functions=80",
    "test:coverage:background": "node scripts/check-background-coverage.mjs",
    "check": "for file in src/*.js scripts/*.mjs; do [ -f \"$file\" ] || continue; node --check \"$file\" || exit 1; done",
    "update:psl": "node scripts/update-public-suffix-list.mjs"
  },
  "devDependencies": {
    "puppeteer-core": "^25.3.0"
  }
}
